# Optional: only needed if enabling LLM rationale (Phase 7)
# ANTHROPIC_API_KEY=sk-ant-...

# Database path (default: sqlite:///./data/koffeeza.db)
# DATABASE_URL=sqlite:///./data/koffeeza.db

# JWT signing secret for multi-user auth.
# If not set, a random key is auto-generated and stored in backend/.secret_key.
# Set this explicitly in Docker/production so tokens survive container rebuilds.
# SECRET_KEY=your-random-secret-here
