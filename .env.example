# LLM rationale — set ENABLE and API_KEY to activate
# ENABLE_LLM_RATIONALE=true
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_RATIONALE_MODEL=claude-haiku-4-20250414
# LLM_RATIONALE_TIMEOUT=5.0

# Database path (default: sqlite:///./data/koffeeza.db)
# DATABASE_URL=sqlite:///./data/koffeeza.db

# JWT signing secret for multi-user auth.
# If not set, a random key is auto-generated and stored in backend/.secret_key.
# Set this explicitly in Docker/production so tokens survive container rebuilds.
# SECRET_KEY=your-random-secret-here

# CORS allowed origins (comma-separated).
# Default: http://localhost:3000,http://localhost:5173
# Set to your production domain in deployment.
# ALLOWED_ORIGINS=https://koffeeza.example.com
